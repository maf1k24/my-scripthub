// app/page.tsx
'use client'

import { useState } from 'react'

const scripts = {
  trade: `loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/FreezeTradeScritp/refs/heads/main/Loader.lua"))()`,
  auto: `loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/AutoPhantomEventScript/refs/heads/main/Loader.lua"))()`,
  candy: `loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/CandyEsp-MiniGame-Script/refs/heads/main/Loader.lua"))()`
}

type ScriptKey = keyof typeof scripts

export default function Home() {
  const [active, setActive] = useState<ScriptKey>('trade')
  const [copied, setCopied] = useState(false)
  const [error, setError] = useState<string | null>(null)

  // Safe copy with fallbacks for restricted environments
  const copy = async () => {
    setCopied(false)
    setError(null)

    const text = scripts[active]

    try {
      // Preferred modern API (requires secure context + user gesture)
      if (typeof navigator !== 'undefined' && navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text)
      } else {
        throw new Error('Clipboard API unavailable')
      }
    } catch (e) {
      try {
        // Fallback using a temporary textarea
        const textarea = document.createElement('textarea')
        textarea.value = text
        textarea.style.position = 'fixed'
        textarea.style.left = '-9999px'
        document.body.appendChild(textarea)
        textarea.focus()
        textarea.select()

        const successful = document.execCommand('copy')
        document.body.removeChild(textarea)

        if (!successful) throw new Error('execCommand failed')
      } catch (err) {
        setError('Copy blocked by browser. Copy manually.')
        return
      }
    }

    setCopied(true)
    setTimeout(() => setCopied(false), 2000)
  }

  return (
    <main className="min-h-screen flex items-center justify-center bg-black text-white relative overflow-hidden">

      {/* GRID BACKGROUND */}
      <div
        className="absolute inset-0 opacity-20"
        style={{
          backgroundImage:
            'linear-gradient(#222 1px, transparent 1px), linear-gradient(90deg, #222 1px, transparent 1px)',
          backgroundSize: '40px 40px'
        }}
      />

      {/* CARD */}
      <div className="relative z-10 w-[420px] bg-zinc-900/80 backdrop-blur-xl border border-zinc-800 rounded-2xl p-6 shadow-[0_0_60px_rgba(168,85,247,0.25)]">

        {/* HEADER */}
        <div className="flex justify-between items-center mb-4">
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 bg-white text-black flex items-center justify-center rounded-md font-bold">M</div>
            <span className="text-sm text-zinc-300">MyScripts</span>
          </div>

          <div className="text-xs bg-green-500/10 text-green-400 px-2 py-1 rounded-full">
            ● 184 online
          </div>
        </div>

        {/* TITLE */}
        <h1 className="text-xl font-semibold mb-1">
          Roblox <span className="text-purple-400">Script Hub</span>
        </h1>
        <p className="text-sm text-zinc-400 mb-4">
          Select a script below and copy it
        </p>

        {/* BUTTONS */}
        <div className="grid grid-cols-2 gap-2 mb-4">
          <button
            onClick={() => setActive('trade')}
            className={`p-2 rounded-lg border ${active === 'trade'
              ? 'bg-purple-600 border-purple-500'
              : 'bg-zinc-800 border-zinc-700 hover:bg-zinc-700'}`}
          >
            Trade Script
          </button>

          <button
            onClick={() => setActive('auto')}
            className={`p-2 rounded-lg border ${active === 'auto'
              ? 'bg-purple-600 border-purple-500'
              : 'bg-zinc-800 border-zinc-700 hover:bg-zinc-700'}`}
          >
            Auto Farm
          </button>

          <button
            onClick={() => setActive('candy')}
            className={`p-2 rounded-lg border col-span-2 ${active === 'candy'
              ? 'bg-purple-600 border-purple-500'
              : 'bg-zinc-800 border-zinc-700 hover:bg-zinc-700'}`}
          >
            Candy Script
          </button>
        </div>

        {/* CODE */}
        <textarea
          value={scripts[active]}
          readOnly
          className="w-full h-28 bg-black border border-zinc-800 rounded-lg p-3 text-sm text-zinc-300 mb-2"
        />

        {/* COPY BUTTON */}
        <button
          onClick={copy}
          className="w-full py-2 rounded-lg bg-gradient-to-r from-purple-600 to-purple-500 hover:opacity-90 transition"
        >
          {copied ? 'Copied!' : 'Copy Script'}
        </button>

        {/* STATUS */}
        {error && (
          <p className="text-red-400 text-xs mt-2">{error}</p>
        )}
        {copied && !error && (
          <p className="text-green-400 text-xs mt-2">Copied to clipboard</p>
        )}

      </div>
    </main>
  )
}
